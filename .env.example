# Contact form configuration — copy this file to `.env.local` and fill in real values.
# These are server-only variables (no NEXT_PUBLIC_ prefix) — they are never sent to
# the browser. Set the same variables in your Vercel dashboard under
# Project → Settings → Environment Variables.

# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=you@example.com

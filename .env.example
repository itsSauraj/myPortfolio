# Contact form (EmailJS) configuration — copy this file to `.env.local`
# and fill in the real values. All VITE_* vars are inlined into the client
# bundle at build time, so the EmailJS PUBLIC key is the only key used here
# (it is publishable by design). For production, set the same variables in
# your Cloudflare dashboard (Workers & Pages → project → Settings →
# Variables and Secrets) so they're inlined during the build.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Where the contact form delivers, and the display name on the email
VITE_CONTACT_EMAIL=you@example.com
VITE_CONTACT_NAME=Your Name
